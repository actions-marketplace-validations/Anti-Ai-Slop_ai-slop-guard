+import { pool } from '../config/database';
+import { AuditEntry, AuditAction, AuditQueryParams } from '../models/audit-log';
+import { randomUUID } from 'crypto';
+
+interface AuditLogInput {
+  userId: string;
+  action: AuditAction;
+  resource: string;
+  resourceId: string;
+  details: Record<string, unknown>;
+}
+
+export class AuditService {
+  async log(input: AuditLogInput): Promise<void> {
+    const id = randomUUID();
+    await pool.query(
+      'INSERT INTO audit_logs (id, user_id, action, resource, resource_id, details, timestamp) VALUES (?, ?, ?, ?, ?, ?, NOW())',
+      [id, input.userId, input.action, input.resource, input.resourceId, JSON.stringify(input.details)]
+    );
+  }
+
+  async query(params: AuditQueryParams): Promise<AuditEntry[]> {
+    let sql = 'SELECT * FROM audit_logs WHERE 1=1';
+    const values: unknown[] = [];
+
+    if (params.userId) { sql += ' AND user_id = ?'; values.push(params.userId); }
+    if (params.action) { sql += ' AND action = ?'; values.push(params.action); }
+    if (params.resource) { sql += ' AND resource = ?'; values.push(params.resource); }
+    if (params.from) { sql += ' AND timestamp >= ?'; values.push(params.from); }
+    if (params.to) { sql += ' AND timestamp <= ?'; values.push(params.to); }
+
+    sql += ' ORDER BY timestamp DESC';
+    if (params.limit) { sql += ' LIMIT ?'; values.push(params.limit); }
+    if (params.offset) { sql += ' OFFSET ?'; values.push(params.offset); }
+
+    const [rows] = await pool.query(sql, values);
+    return rows as AuditEntry[];
+  }
+}
