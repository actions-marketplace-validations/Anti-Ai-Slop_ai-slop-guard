+import { getRedisClient } from './redis';
+
+export interface CacheOptions {
+  ttl: number;
+  prefix: string;
+}
+
+const DEFAULT_TTL = 3600;
+
+export async function cacheGet<T>(key: string, prefix = 'app'): Promise<T | null> {
+  const redis = await getRedisClient();
+  const raw = await redis.get(`${prefix}:${key}`);
+  if (!raw) return null;
+  return JSON.parse(raw) as T;
+}
+
+export async function cacheSet<T>(key: string, value: T, options?: Partial<CacheOptions>): Promise<void> {
+  const redis = await getRedisClient();
+  const prefix = options?.prefix ?? 'app';
+  const ttl = options?.ttl ?? DEFAULT_TTL;
+  const serialized = JSON.stringify(value);
+  await redis.setEx(`${prefix}:${key}`, ttl, serialized);
+}
+
+export async function cacheDelete(key: string, prefix = 'app'): Promise<void> {
+  const redis = await getRedisClient();
+  await redis.del(`${prefix}:${key}`);
+}
