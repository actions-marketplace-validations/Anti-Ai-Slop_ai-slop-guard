+import { pool } from '../config/database';
+import { Session, SessionCreateInput } from '../models/session';
+import { randomUUID } from 'crypto';
+import { sign } from 'jsonwebtoken';
+
+const SESSION_TTL = 86400;
+const JWT_SECRET = process.env.JWT_SECRET ?? 'fallback-secret';
+
+export class SessionRepository {
+  async create(input: SessionCreateInput): Promise<Session> {
+    const id = randomUUID();
+    const ttl = input.ttlSeconds ?? SESSION_TTL;
+    const expiresAt = new Date(Date.now() + ttl * 1000);
+    const token = sign({ sessionId: id, userId: input.userId }, JWT_SECRET, { expiresIn: ttl });
+    const refreshToken = randomUUID();
+
+    await pool.query(
+      'INSERT INTO sessions (id, user_id, token, refresh_token, user_agent, ip_address, expires_at) VALUES (?, ?, ?, ?, ?, ?, ?)',
+      [id, input.userId, token, refreshToken, input.userAgent, input.ipAddress, expiresAt]
+    );
+
+    return {
+      id,
+      userId: input.userId,
+      token,
+      refreshToken,
+      userAgent: input.userAgent,
+      ipAddress: input.ipAddress,
+      expiresAt,
+      createdAt: new Date(),
+      lastActivityAt: new Date(),
+    };
+  }
+
+  async findByToken(token: string): Promise<Session | null> {
+    const [rows] = await pool.query('SELECT * FROM sessions WHERE token = ? AND expires_at > NOW()', [token]);
+    const sessions = rows as Session[];
+    return sessions[0] ?? null;
+  }
+
+  async deleteByUserId(userId: string): Promise<void> {
+    await pool.query('DELETE FROM sessions WHERE user_id = ?', [userId]);
+  }
+}
