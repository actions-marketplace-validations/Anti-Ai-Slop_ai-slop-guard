+  /**
+   * Validates a login attempt against rate limiting rules.
+   * Returns false if the account is temporarily locked due to
+   * too many failed attempts within the time window.
+   */
+  async validateLoginAttempt(email: string): Promise<boolean> {
+    const key = `login:${email}`;
+    const attempts = await this.rateLimiter.getAttempts(key);
+
+    if (attempts >= this.rateLimiter.maxAttempts) {
+      await this.auditLog.record({
+        event: 'LOGIN_BLOCKED',
+        email,
+        reason: 'rate_limit_exceeded',
+        timestamp: new Date(),
+      });
+      return false;
+    }
+
+    return true;
+  }
+
+  /**
+   * Records a failed login attempt and increments the rate limiter counter.
+   */
+  async recordFailedAttempt(email: string): Promise<void> {
+    const key = `login:${email}`;
+    await this.rateLimiter.increment(key);
+
+    const attempts = await this.rateLimiter.getAttempts(key);
+    await this.auditLog.record({
+      event: 'LOGIN_FAILED',
+      email,
+      attemptNumber: attempts,
+      timestamp: new Date(),
+    });
+  }
